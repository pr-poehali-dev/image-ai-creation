{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Me without token returns 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401
    },
    {
      "name": "Register validation fails on empty",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "", "password": "", "name": ""},
      "expectedStatus": 400
    }
  ]
}
